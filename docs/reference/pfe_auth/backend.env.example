# ─── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_USER=pfe
POSTGRES_PASSWORD=change_this_postgres_password
POSTGRES_DB=adaptive_learning

# These are consumed by main.py when running locally (outside Docker).
# Host-mapped port is 5433 (Docker maps 5433→5432 inside container).
DATABASE_URL=postgresql+asyncpg://pfe:change_this_postgres_password@localhost:5433/adaptive_learning

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_this_redis_password

# Consumed by main.py locally; overridden by compose inside Docker.
REDIS_URL=redis://:change_this_redis_password@localhost:6379/0

# ─── JWT ───────────────────────────────────────────────────────────────────
# REQUIRED: generate a random 32+ char string, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_this_to_a_random_32plus_character_secret_key
JWT_ALGORITHM=HS256
# Must be between 5 and 120 minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── Groq LLM ──────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here

# ─── SMTP (optional — OTP emails) ─────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AdaptIQ
SMTP_USE_TLS=true

# ─── App ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── OTP (password reset codes) ────────────────────────────────────────────
OTP_LENGTH=6
OTP_EXPIRE_SECONDS=300
# Max wrong attempts before OTP is invalidated
OTP_MAX_ATTEMPTS=3

# ─── Quiz / Game Rules (all tunable without code changes) ─────────────────
# Time per question in seconds (must match frontend QUIZ_TIME_LIMIT)
QUIZ_TIME_LIMIT_SECONDS=30
# Questions per quiz session
QUIZ_QUESTIONS_PER_SESSION=10
# Base points awarded for a correct answer
POINTS_BASE_AWARD=10
# Time bonus: floor(time_remaining / divisor) added to base award
POINTS_TIME_BONUS_DIVISOR=3
# Points deducted when a hint is used
POINTS_HINT_PENALTY=3
# Points deducted for a wrong answer (cannot go below 0)
POINTS_WRONG_PENALTY=5

# ─── pgAdmin ───────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@adaptiq.local
PGADMIN_PASSWORD=change_this_pgadmin_password
